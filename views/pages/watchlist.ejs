<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/variables.css" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    /* Watchlist Page Specific Styles */
    .watchlist-page {
      min-height: 100vh;
      background-color: var(--color-bg-main);
      padding: var(--spacing-3xl) var(--spacing-xl);
      margin-top: 64px; /* Align below Fixed Navbar */
    }

    .watchlist-container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .watchlist__title {
      font-size: var(--font-size-2xl);
      font-weight: 800;
      color: var(--color-text-primary);
      margin-bottom: var(--spacing-2xl);
    }

    .watchlist-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: var(--spacing-lg);
    }

    .watchlist-card {
      position: relative;
      border-radius: var(--radius-sm);
      overflow: hidden;
      box-shadow: var(--shadow-card);
      transition: transform var(--transition-normal);
      aspect-ratio: 2 / 3;
      background-color: var(--color-bg-card);
      cursor: pointer;
    }

    .watchlist-card:hover {
      transform: scale(1.05);
      z-index: 10;
    }

    .watchlist-card__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .watchlist-card__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.4) 60%, rgba(0, 0, 0, 0) 100%);
      opacity: 0;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: var(--spacing-md);
      transition: opacity var(--transition-normal);
    }

    .watchlist-card:hover .watchlist-card__overlay {
      opacity: 1;
    }

    .watchlist-card__title {
      font-size: var(--font-size-md);
      font-weight: 700;
      color: var(--color-text-primary);
      margin-bottom: var(--spacing-sm);
      line-height: 1.3;
    }

    .watchlist-card__btn {
      font-size: var(--font-size-xs);
      font-weight: 700;
      color: var(--color-text-primary);
      background-color: var(--color-primary);
      padding: var(--spacing-xs) var(--spacing-sm);
      border-radius: var(--radius-sm);
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* Empty Watchlist State */
    .watchlist-empty {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: var(--spacing-3xl) var(--spacing-md);
    }

    .watchlist-empty__icon {
      font-size: 64px;
      margin-bottom: var(--spacing-md);
    }

    .watchlist-empty__text {
      font-size: var(--font-size-xl);
      color: var(--color-text-primary);
      margin-bottom: var(--spacing-sm);
    }

    .watchlist-empty__description {
      font-size: var(--font-size-md);
      color: var(--color-text-muted);
      max-width: 400px;
      margin-bottom: var(--spacing-xl);
    }

    .watchlist-empty__btn {
      padding: var(--spacing-md) var(--spacing-2xl);
    }

    @media (max-width: 768px) {
      .watchlist-grid {
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
      }
    }
  </style>
</head>
<body>

  <%- include('../partials/navbar') %>

  <main class="watchlist-page">
    <div class="watchlist-container">
      <h1 class="watchlist__title">My List</h1>

      <% if (movies.length === 0) { %>
        <div class="watchlist-empty">
          <div class="watchlist-empty__icon">🎬</div>
          <h2 class="watchlist-empty__text">Your list is empty</h2>
          <p class="watchlist-empty__description">
            Explore trending and popular movies to add them to your List.
          </p>
          <a href="/browse" class="btn btn--primary watchlist-empty__btn">
            Browse Movies
          </a>
        </div>
      <% } else { %>
        <div class="watchlist-grid">
          <% movies.forEach((movie) => { %>
            <div class="watchlist-card">
              <a href="/movie/<%= movie.tmdbId %>">
                <img
                  src="<%= movie.poster %>"
                  alt="<%= movie.title %>"
                  class="watchlist-card__img"
                  loading="lazy"
                />
                <div class="watchlist-card__overlay">
                  <h3 class="watchlist-card__title">
                    <%= movie.title %>
                  </h3>
                  <span class="watchlist-card__btn">View Details</span>
                </div>
              </a>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </main>

  <%- include('../partials/footer') %>

</body>
</html>
