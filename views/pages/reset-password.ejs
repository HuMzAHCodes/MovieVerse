<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>

  <!-- ===================== -->
  <!-- CSS                   -->
  <!-- ===================== -->
  <link rel="stylesheet" href="/css/variables.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="auth-page">

  <!-- ===================== -->
  <!-- Navbar                -->
  <!-- ===================== -->
  <%- include('../partials/navbar') %>

  <!-- ===================== -->
  <!-- Reset Password Form   -->
  <!-- ===================== -->
  <main class="auth">
    <div class="auth__container">

      <!-- Heading -->
      <h1 class="auth__title">Reset Password</h1>

      <!-- Description -->
      <p class="auth__description">
        Enter your new password below.
        Make sure it is at least 6 characters long.
      </p>

      <!-- Error Message -->
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="auth__error">
          <%= error %>
        </div>
      <% } %>

      <!-- Reset Password Form -->
      <form
        class="auth__form"
        action="/api/auth/reset-password/<%= token %>"
        method="POST"
      >

        <!-- New Password -->
        <div class="auth__field">
          <input
            type="password"
            name="password"
            placeholder="New password"
            class="auth__input"
            required
            autocomplete="new-password"
            minlength="6"
          />
        </div>

        <!-- Confirm New Password -->
        <div class="auth__field">
          <input
            type="password"
            name="confirmPassword"
            placeholder="Confirm new password"
            class="auth__input"
            required
            autocomplete="new-password"
            minlength="6"
          />
        </div>

        <!-- Submit -->
        <button type="submit" class="btn btn--primary auth__btn">
          Reset Password
        </button>

      </form>

      <!-- Back to Login -->
      <div class="auth__divider">
        <span>Remember your password?</span>
      </div>

      <div class="auth__switch">
        <a href="/login" class="auth__switch-link">
          Back to Sign In
        </a>
      </div>

    </div>
  </main>

  <!-- ===================== -->
  <!-- Footer                -->
  <!-- ===================== -->
  <%- include('../partials/footer') %>

  <!-- ===================== -->
  <!-- JS                    -->
  <!-- ===================== -->
  <script src="/js/main.js"></script>

</body>
</html>