/* =====================
   AUTH TERMS TEXT
===================== */
.auth__terms {
  text-align: center;
  color: var(--color-text-muted);
  font-size: var(--font-size-xs);
  margin-top: var(--spacing-lg);
  line-height: 1.6;
}

.auth__terms a {
  color: var(--color-text-secondary);
  text-decoration: underline;
  transition: color var(--transition-fast);
}

.auth__terms a:hover {
  color: var(--color-text-primary);
}