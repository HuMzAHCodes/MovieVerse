<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/variables.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="auth-page">
  <%- include('../partials/navbar') %>
  <main class="auth">
    <div class="auth__container">
      <h1 class="auth__title">Forgot Password</h1>
      <p class="auth__description">
        Enter your email address and we will send you a link to reset your password.
      </p>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="auth__error"><%= error %></div>
      <% } %>
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="auth__success"><%= success %></div>
      <% } %>
      <form class="auth__form" action="/api/auth/forgot-password" method="POST">
        <div class="auth__field">
          <input type="email" name="email" placeholder="Email address" class="auth__input" required autocomplete="email" />
        </div>
        <button type="submit" class="btn btn--primary auth__btn">Send Reset Link</button>
      </form>
      <div class="auth__divider"><span>Remember your password?</span></div>
      <div class="auth__switch">
        <a href="/login" class="auth__switch-link">Back to Sign In</a>
      </div>
    </div>
  </main>
  <%- include('../partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>