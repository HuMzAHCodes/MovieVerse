<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/variables.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <%- include('../partials/navbar') %>

  <!-- Hero Banner -->
  <% if (heroMovie) { %>
  <section
    class="browse-hero"
    style="background-image: url('<%= heroMovie.backdrop_path %>')"
  >
    <div class="browse-hero__overlay"></div>
    <div class="browse-hero__content">
      <h1 class="browse-hero__title"><%= heroMovie.title %></h1>
      <p class="browse-hero__description">
        <%= heroMovie.overview.slice(0, 150) %>...
      </p>
      <div class="browse-hero__actions">
        <a href="/movie/<%= heroMovie.id %>" class="btn btn--primary">
          ▶ Watch Trailer
        </a>
        <button class="btn btn--secondary">+ My List</button>
      </div>
      <div class="browse-hero__meta">
        <span class="browse-hero__rating">⭐ <%= heroMovie.vote_average.toFixed(1) %></span>
        <span class="browse-hero__year"><%= new Date(heroMovie.release_date).getFullYear() %></span>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Genre Filter Bar -->
  <section class="genre-bar">
    <div class="genre-bar__container">
      <a href="/browse" class="genre-bar__item genre-bar__item--active">All</a>
      <% allGenres.slice(0, 10).forEach((genre) => { %>
        <a href="/genre/<%= genre.id %>" class="genre-bar__item">
          <%= genre.name %>
        </a>
      <% }) %>
    </div>
  </section>

  <!-- Movie Rows -->
  <main class="browse">

    <section class="movie-row">
      <h2 class="movie-row__title">🔥 Trending This Week</h2>
      <div class="movie-row__slider">
        <% trendingMovies.forEach((movie) => { %>
          <%- include('../partials/movie-card', { movie }) %>
        <% }) %>
      </div>
    </section>

    <section class="movie-row">
      <h2 class="movie-row__title">🎬 Popular Movies</h2>
      <div class="movie-row__slider">
        <% popularMovies.forEach((movie) => { %>
          <%- include('../partials/movie-card', { movie }) %>
        <% }) %>
      </div>
    </section>

    <section class="movie-row">
      <h2 class="movie-row__title">⭐ Top Rated</h2>
      <div class="movie-row__slider">
        <% topRatedMovies.forEach((movie) => { %>
          <%- include('../partials/movie-card', { movie }) %>
        <% }) %>
      </div>
    </section>

  </main>

  <%- include('../partials/footer') %>

  <script src="/js/main.js"></script>

</body>
</html>