<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/variables.css" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    /* Admin User Management Specific Styles */
    .admin-page {
      min-height: 100vh;
      background-color: var(--color-bg-main);
      padding: var(--spacing-3xl) var(--spacing-xl);
      margin-top: 64px;
    }

    .admin-container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: var(--spacing-2xl);
      flex-wrap: wrap;
      gap: var(--spacing-md);
    }

    .admin-header__title {
      font-size: var(--font-size-2xl);
      font-weight: 800;
      color: var(--color-text-primary);
    }

    .admin-header__actions {
      display: flex;
      gap: var(--spacing-sm);
    }

    /* Alert Banner */
    .admin-alert {
      padding: var(--spacing-md);
      border-radius: var(--radius-sm);
      margin-bottom: var(--spacing-lg);
      font-size: var(--font-size-sm);
      font-weight: 600;
      text-align: center;
      display: none; /* Controlled via JS */
    }

    .admin-alert--error {
      background-color: rgba(231, 76, 60, 0.15);
      border: 1px solid var(--color-error);
      color: var(--color-error);
    }

    .admin-alert--success {
      background-color: rgba(46, 204, 113, 0.15);
      border: 1px solid var(--color-success);
      color: var(--color-success);
    }

    /* Users Table Section */
    .users-section {
      background-color: var(--color-bg-card);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--spacing-xl);
      box-shadow: var(--shadow-card);
    }

    .users-table-wrapper {
      overflow-x: auto;
    }

    .users-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    .users-table th {
      padding: var(--spacing-md);
      font-size: var(--font-size-xs);
      color: var(--color-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid var(--color-border);
    }

    .users-table td {
      padding: var(--spacing-md);
      font-size: var(--font-size-sm);
      color: var(--color-text-secondary);
      border-bottom: 1px solid var(--color-border);
      vertical-align: middle;
    }

    .users-table tr:last-child td {
      border-bottom: none;
    }

    .users-table__user {
      display: flex;
      align-items: center;
      gap: var(--spacing-sm);
    }

    .users-table__avatar {
      width: 36px;
      height: 36px;
      border-radius: var(--radius-full);
      object-fit: cover;
    }

    .users-table__name {
      font-weight: 600;
      color: var(--color-text-primary);
    }

    .badge {
      display: inline-block;
      padding: 2px var(--spacing-sm);
      border-radius: var(--radius-full);
      font-size: var(--font-size-xs);
      font-weight: 700;
      text-transform: uppercase;
    }

    .badge--admin {
      background-color: rgba(229, 9, 20, 0.15);
      color: var(--color-primary);
      border: 1px solid var(--color-primary);
    }

    .badge--user {
      background-color: rgba(52, 152, 219, 0.15);
      color: var(--color-info);
      border: 1px solid var(--color-info);
    }

    .btn--delete {
      background-color: transparent;
      color: var(--color-error);
      border: 1px solid var(--color-error);
      padding: var(--spacing-xs) var(--spacing-md);
      font-size: var(--font-size-xs);
      font-weight: 700;
      border-radius: var(--radius-sm);
      transition: all var(--transition-fast);
    }

    .btn--delete:hover {
      background-color: var(--color-error);
      color: var(--color-text-primary);
    }

    .btn--delete:disabled {
      opacity: 0.4;
      cursor: not-allowed;
      border-color: var(--color-text-muted);
      color: var(--color-text-muted);
    }

    .btn--delete:disabled:hover {
      background-color: transparent;
      color: var(--color-text-muted);
    }

    @media (max-width: 768px) {
      .admin-page {
        padding: var(--spacing-2xl) var(--spacing-md);
      }
    }
  </style>
</head>
<body>

  <%- include('../partials/navbar') %>

  <main class="admin-page">
    <div class="admin-container">
      
      <!-- Admin Header -->
      <div class="admin-header">
        <h1 class="admin-header__title">User Management</h1>
        <div class="admin-header__actions">
          <a href="/admin" class="btn btn--secondary">
            Back to Dashboard
          </a>
          <a href="/browse" class="btn btn--secondary">
            Exit Admin
          </a>
        </div>
      </div>

      <!-- Alert Banner -->
      <div id="alertBanner" class="admin-alert"></div>

      <!-- Registered Users Table -->
      <div class="users-section">
        <div class="users-table-wrapper">
          <table class="users-table">
            <thead>
              <tr>
                <th>User</th>
                <th>Email</th>
                <th>Role</th>
                <th>Joined</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody id="usersTableBody">
              <% users.forEach((item) => { %>
                <tr id="row-<%= item._id %>">
                  <td>
                    <div class="users-table__user">
                      <img
                        src="<%= item.avatar || '/images/default-avatar.png' %>"
                        alt="<%= item.name %>"
                        class="users-table__avatar"
                      />
                      <span class="users-table__name"><%= item.name %></span>
                    </div>
                  </td>
                  <td><%= item.email %></td>
                  <td>
                    <span class="badge badge--<%= item.role %>">
                      <%= item.role %>
                    </span>
                  </td>
                  <td><%= new Date(item.createdAt).toLocaleDateString() %></td>
                  <td>
                    <button
                      class="btn--delete deleteUserBtn"
                      data-user-id="<%= item._id %>"
                      data-user-name="<%= item.name %>"
                      <%= item._id.toString() === user._id.toString() ? 'disabled' : '' %>
                    >
                      Delete
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </main>

  <%- include('../partials/footer') %>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const usersTableBody = document.getElementById('usersTableBody');
      const alertBanner = document.getElementById('alertBanner');

      const showAlert = (message, type) => {
        alertBanner.textContent = message;
        alertBanner.className = `admin-alert admin-alert--${type}`;
        alertBanner.style.display = 'block';

        // Auto hide after 4 seconds
        setTimeout(() => {
          alertBanner.style.display = 'none';
        }, 4000);
      };

      if (usersTableBody) {
        usersTableBody.addEventListener('click', async (e) => {
          if (e.target.classList.contains('deleteUserBtn')) {
            const btn = e.target;
            const userId = btn.dataset.userId;
            const userName = btn.dataset.userName;

            const confirmDelete = confirm(`Are you sure you want to delete user "${userName}"? This will permanently remove their watchlist and account credentials.`);
            
            if (confirmDelete) {
              try {
                const response = await fetch(`/api/admin/users/${userId}`, {
                  method: 'DELETE',
                });
                const data = await response.json();

                if (data.success) {
                  // Remove row from table
                  const row = document.getElementById(`row-${userId}`);
                  if (row) row.remove();

                  showAlert(data.message, 'success');
                } else {
                  showAlert(data.message || 'Failed to delete user', 'error');
                }
              } catch (err) {
                console.error('Delete user error:', err);
                showAlert('Network error, please try again.', 'error');
              }
            }
          }
        });
      }
    });
  </script>

</body>
</html>
