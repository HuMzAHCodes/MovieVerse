<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>

  <!-- ===================== -->
  <!-- CSS                   -->
  <!-- ===================== -->
  <link rel="stylesheet" href="/css/variables.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <!-- ===================== -->
  <!-- Navbar                -->
  <!-- ===================== -->
  <%- include('../partials/navbar') %>

  <!-- ===================== -->
  <!-- Genre Page            -->
  <!-- ===================== -->
  <main class="genre-page">

    <!-- ===================== -->
    <!-- Genre Header         -->
    <!-- ===================== -->
    <section class="genre-header">
      <div class="genre-header__container">
        <a href="/browse" class="genre-header__back">
          ← Back to Browse
        </a>
        <h1 class="genre-header__title">
          <%= currentGenre ? currentGenre.name : 'Movies' %>
        </h1>
        <p class="genre-header__subtitle">
          Browse all <%= currentGenre ? currentGenre.name : '' %> movies
        </p>
      </div>
    </section>

    <!-- ===================== -->
    <!-- Genre Filter Bar     -->
    <!-- ===================== -->
    <section class="genre-bar">
      <div class="genre-bar__container">
        <a href="/browse" class="genre-bar__item">
          All
        </a>
        <% allGenres.slice(0, 10).forEach((genre) => { %>
          
            href="/genre/<%= genre.id %>"
            class="genre-bar__item
              <%= currentGenre && currentGenre.id === genre.id
                ? 'genre-bar__item--active' : '' %>"
          >
            <%= genre.name %>
          </a>
        <% }) %>
      </div>
    </section>

    <!-- ===================== -->
    <!-- Movies Grid          -->
    <!-- ===================== -->
    <section class="genre-results">
      <div class="genre-results__container">

        <% if (movies.length === 0) { %>
          <!-- No Movies Found -->
          <div class="search-results__empty">
            <p class="search-results__empty-icon">🎬</p>
            <p class="search-results__empty-text">
              No movies found for this genre
            </p>
            <a href="/browse" class="btn btn--primary">
              Back to Browse
            </a>
          </div>

        <% } else { %>
          <!-- Movies Grid -->
          <div class="search-results__grid">
            <% movies.forEach((movie) => { %>
              <%- include('../partials/movie-card', { movie }) %>
            <% }) %>
          </div>

          <!-- ===================== -->
          <!-- Pagination           -->
          <!-- ===================== -->
          <% if (totalPages > 1) { %>
          <div class="pagination">

            <!-- Previous -->
            <% if (currentPage > 1) { %>
              
                href="/genre/<%= currentGenre.id %>?page=<%= currentPage - 1 %>"
                class="pagination__btn"
              >
                ← Previous
              </a>
            <% } %>

            <!-- Page Numbers -->
            <div class="pagination__pages">
              <%
                const startPage = Math.max(1, currentPage - 2);
                const endPage   = Math.min(totalPages, currentPage + 2);
                for (let i = startPage; i <= endPage; i++) {
              %>
                
                  href="/genre/<%= currentGenre.id %>?page=<%= i %>"
                  class="pagination__page
                    <%= i === currentPage
                      ? 'pagination__page--active' : '' %>"
                >
                  <%= i %>
                </a>
              <% } %>
            </div>

            <!-- Next -->
            <% if (currentPage < totalPages) { %>
              
                href="/genre/<%= currentGenre.id %>?page=<%= currentPage + 1 %>"
                class="pagination__btn"
              >
                Next →
              </a>
            <% } %>

          </div>
          <% } %>

        <% } %>

      </div>
    </section>

  </main>

  <!-- ===================== -->
  <!-- Footer                -->
  <!-- ===================== -->
  <%- include('../partials/footer') %>

  <!-- ===================== -->
  <!-- JS                    -->
  <!-- ===================== -->
  <script src="/js/main.js"></script>

</body>
</html>